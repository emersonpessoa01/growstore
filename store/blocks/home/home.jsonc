{
  "store.home": {
    "blocks": [
      // "list-context.image-list#demo",
      /* You can make references to blocks defined in other files.
       * For example, `flex-layout.row#deals` is defined in the `deals.json` file. */
      "flex-layout.row#deals",
      "benefits-banner",
      // "__fold__",
      // "rich-text#shelf-title",
      // "flex-layout.row#shelf",
      // "info-card#home",
      // "rich-text#question",
      // "rich-text#link",
      // "newsletter"
      "flex-layout.row#example"
    ]
  },
  "benefits-banner": {
    "props": {
      "id": "benefits-banner-home",
      "layout": "horizontal",
      "iconUrl1": "https://cdn-icons-png.flaticon.com/512/2769/2769339.png",
      "mainText1": "Frete Grátis",
      "subText1": "Em compras acima de R$ 150,00",
      "iconUrl2": "https://cdn-icons-png.flaticon.com/512/4021/4021708.png",
      "mainText2": "Até 6x Sem Juros",
      "subText2": "Ou desconto no PIX",
      "iconUrl3": "https://cdn-icons-png.flaticon.com/512/5637/5637217.png",
      "mainText3": "Entrega Rápida",
      "subText3": "Receba em tempo recorde"
    }
  },

  /* BLOCKS A SEREM MOSTRADOS NA HOME */
  "flex-layout.row#example": {
    "title": "Infos detail",
    "children": ["flex-layout.col#col-image", "flex-layout.col#col-text"],
    "props": {
      "blockClass": "custom-padding"
    }
    // <div class="row classe-custom-flexrow">
    //   <div class="col">
    //        <img alt="" src="" title="" />
    //    </div>
    //   <div class="col">
    //       <h2>fgdnfjngk</h2>
    //       <p></p>
    //    </div>
    // </div>
  },
  "flex-layout.col#col-image": {
    "title": "Container Image",
    "children": ["image#product-image"],
    "props": {
      "horizontalAlign": "center",
      "blockClass": "custom-border-col-image"
    }
  },
  "image#product-image": {
    "title": "Image Left",
    "props": {
      "alt": "Image product example",
      "src": "assets/images/sofa.png",
      "blockClass": "image-custom"
    }
  },
  "flex-layout.col#col-text": {
    "title": "Container Text",
    "children": ["rich-text#title", "rich-text#description"],
    "props": {
      "verticalAlign": "middle"
    }
  },
  "rich-text#title": {
    "title": "Titulo",
    "props": {
      "text": "## Title of product"
    }
  },
  "rich-text#description": {
    "title": "Descrição",
    "props": {
      "text": "- Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nullam vulputate odio bibendum, molestie justo et, ultrices quam. Aenean at hendrerit purus, non blandit augue. Morbi sit amet justo id massa commodo fringilla. Proin non porttitor augue, sed porta felis. Ut aliquam euismod lobortis. Integer non ipsum urna. Aenean dapibus justo nulla, finibus hendrerit ipsum laoreet vitae. Integer hendrerit, tellus at fringilla ornare, purus diam faucibus tortor, id volutpat eros neque ut urna. Integer non nisi quis urna tincidunt dignissim id et ipsum.**Suspendisse laoreet tincidunt nisi non viverra. Proin lobortis massa nec dui** consectetur dapibus. Aenean pretium viverra augue vitae rutrum. Maecenas malesuada sodales semper. In diam ligula, semper in feugiat ut, luctus vel nibh. Phasellus ultricies ipsum ac aliquam sollicitudin. Morbi eget sapien nec elit scelerisque tempus ac id nulla. Aenean vitae dui purus.*Suspendisse non turpis ut dolor egestas consectetur ut a tortor*. "
    }
  },
  "info-card#home": {
    "props": {
      "id": "info-card-home",
      "isFullModeStyle": false,
      "textPosition": "left",
      "imageUrl": "https://storecomponents.vteximg.com.br/arquivos/banner-infocard2.png",
      "headline": "Clearance Sale",
      "callToActionText": "DISCOVER",
      "callToActionUrl": "/sale/d",
      "blockClass": "info-card-home",
      "textAlignment": "center"
    }
  }
}
